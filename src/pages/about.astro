---
// src/pages/about.astro
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Stats from "../components/Stats.astro";
import Team from "../components/Team.astro";
import Booking from "../components/Booking.astro";
import Footer from "../components/Footer.astro";

const values = [
    {
        icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
        title: "Compassionate Care",
        desc: "We treat every patient like family, prioritizing your comfort and easing dental anxiety at every step.",
    },
    {
        icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
        title: "Honest & Transparent",
        desc: "No hidden fees or surprise treatments. We explain every option clearly so you are always in control.",
    },
    {
        icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
        title: "Clinical Excellence",
        desc: "Equipped with modern technology and over two decades of experience to ensure the highest quality results.",
    },
];
---

<Layout title="About Us | Gentle Dental">
    <Navbar />

    <main class="pt-32">
        <section class="max-w-7xl mx-auto px-6 mb-20 text-center">
            <div
                class="inline-block bg-brand-light text-brand-primary font-medium px-5 py-2 rounded-full mb-6"
            >
                Our Story
            </div>
            <h1
                class="text-5xl md:text-7xl font-light text-brand-dark mb-8 tracking-tight leading-tight max-w-4xl mx-auto"
            >
                Changing the way you <span
                    class="text-brand-primary font-medium"
                    >feel about the dentist.</span
                >
            </h1>

            <div
                class="w-full h-[300px] md:h-[500px] rounded-[30px] md:rounded-[40px] overflow-hidden shadow-soft border border-gray-50 relative mt-12"
            >
                <img
                    src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?q=80&w=1600&auto=format&fit=crop"
                    alt="Gentle Dental Clinic"
                    class="w-full h-full object-cover"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-brand-dark/20 to-transparent"
                >
                </div>
            </div>
        </section>

        <section
            class="max-w-7xl mx-auto px-6 py-16 md:py-24 grid lg:grid-cols-2 gap-16 items-center"
        >
            <div>
                <h2
                    class="text-3xl md:text-5xl font-light text-brand-dark mb-6 leading-tight"
                >
                    Over a decade of <br /><span
                        class="text-brand-primary font-medium"
                        >trusted family care.</span
                    >
                </h2>
                <div class="w-20 h-1 bg-brand-light mb-8"></div>
                <p class="text-gray-600 text-lg leading-relaxed mb-6">
                    Established in Burwood East, Gentle Dental was founded on a
                    simple premise: dental care shouldn't be scary. For over 12
                    years, we have been dedicated to transforming the clinical,
                    often intimidating dental experience into something warm,
                    welcoming, and entirely centered around patient comfort.
                </p>
                <p class="text-gray-600 text-lg leading-relaxed mb-8">
                    Led by Dr. Gayali Mudalige, our team understands that trust
                    is the foundation of good healthcare. Whether you are
                    bringing in your toddler for their first check-up, or you
                    are an adult who has been avoiding the dentist for years, we
                    meet you exactly where you are, without judgment.
                </p>
            </div>

            <div class="grid grid-cols-2 gap-4 h-full">
                <div
                    class="rounded-[24px] overflow-hidden shadow-sm h-48 md:h-64 mt-8"
                >
                    <img
                        src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?q=80&w=600&auto=format&fit=crop"
                        alt="Dental tools"
                        class="w-full h-full object-cover"
                    />
                </div>
                <div
                    class="rounded-[24px] overflow-hidden shadow-sm h-48 md:h-64"
                >
                    <img
                        src="https://images.unsplash.com/photo-1600170311833-c2cf5280ce49?q=80&w=600&auto=format&fit=crop"
                        alt="Happy patient"
                        class="w-full h-full object-cover"
                    />
                </div>
            </div>
        </section>

        <section class="bg-gray-50/50 py-24">
            <div class="max-w-7xl mx-auto px-6">
                <div class="text-center mb-16">
                    <h2
                        class="text-4xl md:text-5xl font-light text-brand-dark tracking-tight"
                    >
                        Our <span class="text-brand-primary font-medium"
                            >core values</span
                        >
                    </h2>
                </div>

                <div class="grid md:grid-cols-3 gap-8">
                    {
                        values.map((value) => (
                            <div class="bg-white rounded-[32px] p-10 shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-2 transition-all duration-300">
                                <div class="w-14 h-14 rounded-full bg-brand-light flex items-center justify-center text-brand-primary mb-6">
                                    <svg
                                        class="w-6 h-6"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        stroke-width="2"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d={value.icon}
                                        />
                                    </svg>
                                </div>
                                <h3 class="text-xl font-bold text-brand-dark mb-3">
                                    {value.title}
                                </h3>
                                <p class="text-gray-500 leading-relaxed">
                                    {value.desc}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <div class="mt-12">
            <Stats />
        </div>

        <Team />
        <Booking />
    </main>

    <Footer />
</Layout>
