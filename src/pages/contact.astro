---
// src/pages/contact.astro
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Booking from "../components/Booking.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";

const contactMethods = [
    {
        icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z",
        title: "Call us directly",
        desc: "For emergencies or immediate assistance, our phones are answered during clinic hours.",
        action: "(03) 9792 9775",
        link: "tel:0397929775",
    },
    {
        icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z",
        title: "Visit the clinic",
        desc: "Off-street and on-street parking is available right outside for your convenience.",
        action: "332 Blackburn Road, Burwood East",
        link: "https://www.google.com.au/maps/place/332+Blackburn+Rd,+Burwood+East+VIC+3151",
    },
    {
        icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
        title: "Opening hours",
        desc: "Mon, Wed, Thu: 9:30am – 5:30pm",
        action: "Tue, Fri, Weekends: Closed",
        link: "#booking",
    },
];
---

<Layout title="Contact Us | Gentle Dental">
    <Navbar />

    <main>
        <section
            class="relative bg-gradient-to-br from-brand-primary to-[#0ea5e9] min-h-[60vh] flex items-center py-20 overflow-hidden rounded-[30px] md:rounded-[50px] mx-4 sm:mx-6 xl:mx-10 mt-24 mb-20 shadow-soft"
        >
            <div
                class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/3 w-[600px] h-[600px] lg:w-[800px] lg:h-[800px] pointer-events-none z-0 hidden md:block"
            >
                <div
                    class="absolute inset-0 border-[1.5px] border-white/20 rounded-full"
                >
                </div>
                <div
                    class="absolute top-[15%] left-[15%] right-[15%] bottom-[15%] border-[1.5px] border-white/20 rounded-full"
                >
                </div>
                <div
                    class="absolute top-[30%] left-[30%] right-[30%] bottom-[30%] border-[1.5px] border-white/20 rounded-full"
                >
                </div>
            </div>

            <div
                class="w-full max-w-7xl mx-auto px-6 lg:px-12 grid lg:grid-cols-2 gap-12 items-center relative z-10"
            >
                <div class="text-white mt-8 lg:mt-0 text-center lg:text-left">
                    <div
                        class="inline-block bg-white/20 backdrop-blur-sm text-white font-medium px-5 py-2 rounded-full mb-6"
                    >
                        Get In Touch
                    </div>
                    <h1
                        class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] mb-6 tracking-tight"
                    >
                        We'd love to <br class="hidden lg:block" />
                        <span class="text-cyan-200">hear from you.</span>
                    </h1>
                    <p
                        class="text-lg md:text-xl text-white/90 mb-10 max-w-lg mx-auto lg:mx-0 font-medium"
                    >
                        Whether you have a question about a treatment, need help
                        with payment plans, or are experiencing a dental
                        emergency, our team is ready to help.
                    </p>
                </div>

                <div class="relative flex justify-center lg:justify-end">
                    <div
                        class="w-full max-w-md aspect-square rounded-[30px] overflow-hidden shadow-2xl border-4 border-white/30 relative z-10 bg-white"
                    >
                        <img
                            src="https://images.unsplash.com/photo-1663755489920-5e09f66d011a?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                            alt="Gentle Dental Consultation"
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>
            </div>
        </section>

        <section class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid md:grid-cols-3 gap-8">
                {
                    contactMethods.map((method) => (
                        <a
                            href={method.link}
                            class="bg-white rounded-[32px] p-10 shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-2 transition-all duration-300 group flex flex-col items-center text-center"
                        >
                            <div class="w-16 h-16 rounded-full bg-brand-light flex items-center justify-center text-brand-primary mb-6 group-hover:scale-110 transition-transform duration-500">
                                <svg
                                    class="w-7 h-7"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    stroke-width="2"
                                >
                                    {method.icon.split(" M").map((path) => (
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d={
                                                path.startsWith("M")
                                                    ? path
                                                    : "M" + path
                                            }
                                        />
                                    ))}
                                </svg>
                            </div>

                            <h3 class="text-xl font-bold text-brand-dark mb-3">
                                {method.title}
                            </h3>
                            <p class="text-gray-500 leading-relaxed flex-1 mb-6">
                                {method.desc}
                            </p>

                            <div class="text-brand-primary font-semibold group-hover:text-cyan-400 transition-colors">
                                {method.action}
                            </div>
                        </a>
                    ))
                }
            </div>
        </section>

        <section class="max-w-7xl mx-auto px-4 sm:px-6 mb-24">
            <div
                class="relative w-full h-[400px] md:h-[500px] rounded-[32px] md:rounded-[40px] overflow-hidden border-[6px] border-brand-light shadow-sm group"
            >
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3150.4140652548185!2d145.15192729999998!3d-37.8506009!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6ad63f71a8fab2b1%3A0xbb59d886e38ecf20!2s332%20Blackburn%20Rd%2C%20Burwood%20East%20VIC%203151%2C%20Australia!5e0!3m2!1sen!2slk!4v1776142489911!5m2!1sen!2slk"
                    class="absolute inset-0 w-full h-full grayscale-[80%] contrast-125 opacity-80"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                >
                </iframe>
                <div
                    class="absolute inset-0 bg-brand-primary mix-blend-color opacity-40 pointer-events-none group-hover:opacity-0 transition-opacity duration-700"
                >
                </div>

                <div
                    class="absolute bottom-8 left-8 bg-white p-6 rounded-[24px] shadow-xl border border-gray-50 hidden sm:block pointer-events-none"
                >
                    <div class="flex items-center gap-3 mb-2">
                        <div
                            class="w-8 h-8 rounded-full bg-brand-light flex items-center justify-center text-brand-primary"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"
                                ></path><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                ></path></svg
                            >
                        </div>
                        <span class="font-bold text-brand-dark"
                            >Gentle Dental</span
                        >
                    </div>
                    <p class="text-sm text-gray-500 ml-11">
                        332 Blackburn Road,<br />Burwood East, VIC 3151
                    </p>
                </div>
            </div>
        </section>

        <Booking />
        <FAQ />
    </main>

    <Footer />
</Layout>
