---
// src/components/Blog.astro

// 1. Use Vite's native glob instead of Astro.glob
const matches = import.meta.glob("../posts/*.mdx", { eager: true });
const posts = Object.values(matches);

// 2. Sort posts by date (newest first)
posts.sort(
    (a: any, b: any) =>
        new Date(b.frontmatter.date).valueOf() -
        new Date(a.frontmatter.date).valueOf(),
);
---

<section class="py-24 bg-brand-light/30" id="blog">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
            <h2
                class="text-5xl md:text-6xl font-light text-brand-primary/70 mb-4 tracking-tight leading-tight"
            >
                Dental health &<br />
                wellness <span class="text-brand-primary font-medium">tips</span
                >
            </h2>
            <p class="text-brand-primary text-base md:text-lg">
                Expert advice to help you maintain a healthy, beautiful smile.
            </p>
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8"
        >
            {
                posts.map((post: any) => {
                    const { title, category, date, image } = post.frontmatter;

                    // 3. Vite exports the compiled Astro/MDX component as 'default'
                    const Content = post.default;

                    return (
                        <button
                            class="blog-card text-left bg-white rounded-[24px] shadow-sm hover:shadow-xl transition-all duration-300 group flex flex-col overflow-hidden transform hover:-translate-y-2 focus:outline-none"
                            data-title={title}
                            data-category={category}
                            data-date={date}
                            data-image={image}
                        >
                            <div class="hidden post-content">
                                <Content />
                            </div>

                            <div class="h-[240px] md:h-[280px] w-full overflow-hidden shrink-0">
                                <img
                                    src={image}
                                    alt={title}
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out"
                                />
                            </div>

                            <div class="p-6 md:p-8 flex flex-col flex-1">
                                <div class="flex flex-wrap gap-3 mb-5">
                                    <span class="bg-brand-light text-brand-primary text-xs font-medium px-4 py-1.5 rounded-full">
                                        {category}
                                    </span>
                                    <span class="bg-brand-light text-brand-primary text-xs font-medium px-4 py-1.5 rounded-full">
                                        {date}
                                    </span>
                                </div>
                                <h3 class="text-xl md:text-2xl text-brand-primary font-medium leading-snug group-hover:text-cyan-400 transition-colors">
                                    {title}
                                </h3>
                            </div>
                        </button>
                    );
                })
            }
        </div>
    </div>
</section>

<div
    id="blog-modal"
    class="fixed inset-0 z-[100] bg-brand-dark/60 backdrop-blur-sm hidden items-center justify-center opacity-0 transition-opacity duration-300 p-4 sm:p-6 md:p-12"
>
    <div
        id="blog-modal-content"
        class="bg-white rounded-[32px] shadow-2xl w-full max-w-4xl max-h-full overflow-hidden transform translate-y-8 transition-transform duration-300 flex flex-col relative"
    >
        <button
            id="close-blog-btn"
            class="absolute top-4 right-4 sm:top-6 sm:right-6 w-12 h-12 bg-white/80 backdrop-blur-md rounded-full flex items-center justify-center text-brand-dark hover:text-brand-primary hover:bg-brand-light transition-colors shadow-sm z-20"
        >
            <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path></svg
            >
        </button>

        <div class="overflow-y-auto w-full h-full">
            <div class="w-full h-[250px] sm:h-[350px] relative">
                <img
                    id="modal-image"
                    src=""
                    alt="Article image"
                    class="w-full h-full object-cover"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"
                >
                </div>
                <div
                    class="absolute bottom-6 left-6 sm:bottom-10 sm:left-10 flex gap-3"
                >
                    <span
                        id="modal-category"
                        class="bg-brand-primary text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wide"
                    ></span>
                    <span
                        id="modal-date"
                        class="bg-white/90 text-brand-dark text-xs font-bold px-4 py-1.5 rounded-full"
                    ></span>
                </div>
            </div>

            <div class="p-6 sm:p-10 md:p-16 max-w-3xl mx-auto">
                <h2
                    id="modal-title"
                    class="text-3xl md:text-5xl font-bold text-brand-dark mb-10 leading-tight"
                >
                </h2>

                <div
                    id="modal-body"
                    class="prose prose-lg prose-cyan max-w-none text-gray-600 leading-relaxed"
                >
                </div>

                <div class="mt-16 pt-8 border-t border-gray-100 text-center">
                    <p class="text-brand-dark font-medium mb-4">
                        Have questions about your dental health?
                    </p>
                    <a
                        href="#booking"
                        onclick="document.getElementById('close-blog-btn').click()"
                        class="inline-block bg-brand-primary text-white px-8 py-3 rounded-full font-medium hover:bg-cyan-400 transition-colors shadow-soft"
                    >
                        Book an appointment
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const modal = document.getElementById("blog-modal");
    const modalContent = document.getElementById("blog-modal-content");
    const closeBtn = document.getElementById("close-blog-btn");
    const blogCards = document.querySelectorAll(".blog-card");

    const mTitle = document.getElementById("modal-title");
    const mCategory = document.getElementById("modal-category");
    const mDate = document.getElementById("modal-date");
    const mImage = document.getElementById("modal-image");
    const mBody = document.getElementById("modal-body");

    function openBlog(event) {
        const card = event.currentTarget;

        mTitle.textContent = card.dataset.title;
        mCategory.textContent = card.dataset.category;
        mDate.textContent = card.dataset.date;
        mImage.src = card.dataset.image;
        mBody.innerHTML = card.querySelector(".post-content").innerHTML;

        modal.classList.remove("hidden");
        modal.classList.add("flex");
        document.body.style.overflow = "hidden";

        setTimeout(() => {
            modal.classList.remove("opacity-0");
            modalContent.classList.remove("translate-y-8");
        }, 10);
    }

    function closeBlog() {
        modal.classList.add("opacity-0");
        modalContent.classList.add("translate-y-8");
        document.body.style.overflow = "";

        setTimeout(() => {
            modal.classList.remove("flex");
            modal.classList.add("hidden");
        }, 300);
    }

    blogCards.forEach((card) => card.addEventListener("click", openBlog));
    closeBtn.addEventListener("click", closeBlog);

    modal.addEventListener("click", (e) => {
        if (e.target === modal) closeBlog();
    });

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal.classList.contains("hidden"))
            closeBlog();
    });
</script>
