---
// src/components/FAQ.astro
const faqs = [
    {
        question: "Are you currently accepting new patients?",
        answer: "Yes, we are always happy to welcome new patients to the Gentle Dental family! Whether you need a routine check-up or emergency care, our doors are open.",
    },
    {
        question: "How do you handle nervous patients?",
        answer: "Anxiety-free dentistry is our specialty. Dr. Gayali has over 23 years of experience calming nervous patients. We take things at your pace, explain everything clearly, and provide a completely non-judgmental environment.",
    },
    {
        question: "Do you offer flexible payment plans?",
        answer: "Absolutely. We believe everyone deserves a healthy smile. We offer honest, transparent pricing with no hidden fees, and we can arrange flexible payment plans to suit your budget.",
    },
    {
        question:
            "At what age should I bring my child in for their first visit?",
        answer: "We recommend booking your child's first dental visit by their first birthday, or when their first tooth appears. Early visits help them get comfortable with the clinic and set them up for a lifetime of good oral health.",
    },
    {
        question: "What should I do if I have a dental emergency?",
        answer: "Please call our clinic immediately at (03) 9792 9775. We prioritize dental emergencies and will do our absolute best to see you and get you out of pain on the same day.",
    },
];
---

<section
    class="relative bg-gradient-to-br from-brand-primary to-[#0ea5e9] py-20 md:py-28 overflow-hidden rounded-[30px] md:rounded-[50px] mx-4 sm:mx-6 xl:mx-10 my-24 shadow-soft"
>
    <div
        class="absolute top-0 right-0 w-[600px] h-[600px] md:w-[800px] md:h-[800px] border-[1.5px] border-white/10 rounded-full flex items-center justify-center pointer-events-none translate-x-1/3 -translate-y-1/3 z-0"
    >
        <div
            class="w-[75%] h-[75%] border-[1.5px] border-white/10 rounded-full flex items-center justify-center"
        >
            <div
                class="w-[70%] h-[70%] border-[1.5px] border-white/10 rounded-full"
            >
            </div>
        </div>
    </div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
            <h2
                class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight"
            >
                Got questions?<br />
                We have <span class="text-white/80 font-light">answers.</span>
            </h2>
            <p class="text-white/90 text-lg max-w-2xl mx-auto font-medium">
                Everything you need to know about your visit to Gentle Dental.
            </p>
        </div>

        <div class="flex flex-col gap-4">
            {
                faqs.map((faq) => (
                    <details class="group bg-white rounded-[20px] shadow-lg hover:shadow-xl overflow-hidden transition-all duration-300 [&_summary::-webkit-details-marker]:hidden cursor-pointer">
                        <summary class="flex items-center justify-between p-6 md:p-8 list-none select-none">
                            <span class="text-brand-dark text-lg md:text-xl font-bold group-hover:text-brand-primary transition-colors pr-6">
                                {faq.question}
                            </span>

                            <div class="w-10 h-10 rounded-full bg-brand-light flex items-center justify-center text-brand-primary transition-transform duration-500 group-open:rotate-45 shrink-0">
                                <svg
                                    class="w-5 h-5"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    stroke-width="2.5"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M12 4v16m8-8H4"
                                    />
                                </svg>
                            </div>
                        </summary>

                        <div class="px-6 md:px-8 pb-8 pt-0">
                            <div class="w-full h-px bg-gray-100 mb-6" />
                            <p class="text-gray-600 leading-relaxed text-base md:text-lg">
                                {faq.answer}
                            </p>
                        </div>
                    </details>
                ))
            }
        </div>
    </div>
</section>

<style>
    /* Smooth open/close animation */
    details[open] summary ~ * {
        animation: faqSlideDown 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @keyframes faqSlideDown {
        0% {
            opacity: 0;
            transform: translateY(-10px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
