---
// src/components/Stats.astro
const stats = [
    { number: "12+", label: "Years of dental expertise" },
    { number: "4,000+", label: "Nervous patients calmed" },
    { number: "1,000+", label: "Happy smiles delivered" },
];
---

<section class="max-w-7xl mx-auto px-6 relative z-20 pb-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {
            stats.map((stat) => (
                <div class="bg-white rounded-card p-10 lg:p-14 text-center shadow-sm border border-gray-50 transform transition-all duration-500 hover:-translate-y-3 hover:shadow-xl group">
                    <h3 class="text-6xl md:text-7xl lg:text-[84px] font-light text-brand-primary mb-3 md:mb-5 tracking-tight group-hover:scale-105 transition-transform duration-500 origin-center">
                        {stat.number}
                    </h3>
                    <p class="text-brand-primary font-medium text-base lg:text-lg">
                        {stat.label}
                    </p>
                </div>
            ))
        }
    </div>
</section>
