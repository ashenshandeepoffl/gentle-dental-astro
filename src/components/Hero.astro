---
// src/components/Hero.astro
---

<section
    class="relative bg-gradient-to-br from-brand-primary to-[#0ea5e9] min-h-[85vh] flex items-center py-20 overflow-hidden rounded-[30px] md:rounded-[50px] mx-4 sm:mx-6 xl:mx-10 mt-24 shadow-soft"
>
    <div
        class="w-full px-6 md:px-12 lg:px-20 grid lg:grid-cols-2 gap-12 items-center relative z-10"
    >
        <div class="text-white mt-8 lg:mt-0">
            <h1
                class="text-5xl md:text-7xl lg:text-[80px] font-bold leading-[1.1] mb-6 tracking-tight"
            >
                Brighter smiles,<br />
                healthier lives.
            </h1>
            <p
                class="text-lg md:text-xl text-white/90 mb-10 max-w-lg font-medium"
            >
                Modern dental care for a confident smile. Your Trusted Family
                Dentist in Dandenong.
            </p>

            <a
                href="#booking"
                class="inline-flex items-center gap-4 bg-white text-brand-primary font-semibold py-2 pl-6 pr-2 rounded-full hover:bg-brand-light transition-all shadow-lg hover:shadow-xl group"
            >
                Book appointment
                <span
                    class="bg-brand-primary text-white p-3 rounded-full group-hover:bg-[#0ea5e9] transition-colors"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="2.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"></path>
                    </svg>
                </span>
            </a>

            <div class="mt-12 flex items-center gap-4">
                <div class="flex -space-x-3">
                    <div
                        class="w-10 h-10 rounded-full bg-[#f8f9fa] border-2 border-[#40c4ff] overflow-hidden flex items-center justify-center"
                    >
                        <img
                            src="https://api.dicebear.com/8.x/notionists/svg?seed=Felix&backgroundColor=transparent"
                            alt="Patient avatar"
                            class="w-8 h-8"
                        />
                    </div>
                    <div
                        class="w-10 h-10 rounded-full bg-[#f8f9fa] border-2 border-[#40c4ff] overflow-hidden flex items-center justify-center"
                    >
                        <img
                            src="https://api.dicebear.com/8.x/notionists/svg?seed=Aneka&backgroundColor=transparent"
                            alt="Patient avatar"
                            class="w-8 h-8"
                        />
                    </div>
                    <div
                        class="w-10 h-10 rounded-full bg-[#f8f9fa] border-2 border-[#40c4ff] overflow-hidden flex items-center justify-center hidden sm:flex"
                    >
                        <img
                            src="https://api.dicebear.com/8.x/notionists/svg?seed=Jasper&backgroundColor=transparent"
                            alt="Patient avatar"
                            class="w-8 h-8"
                        />
                    </div>
                    <div
                        class="w-10 h-10 rounded-full bg-[#f8f9fa] border-2 border-[#40c4ff] overflow-hidden flex items-center justify-center hidden sm:flex"
                    >
                        <img
                            src="https://api.dicebear.com/8.x/notionists/svg?seed=Nala&backgroundColor=transparent"
                            alt="Patient avatar"
                            class="w-8 h-8"
                        />
                    </div>
                    <div
                        class="w-10 h-10 rounded-full bg-[#f8f9fa] border-2 border-[#40c4ff] overflow-hidden flex items-center justify-center"
                    >
                        <img
                            src="https://api.dicebear.com/8.x/notionists/svg?seed=Buster&backgroundColor=transparent"
                            alt="Patient avatar"
                            class="w-8 h-8"
                        />
                    </div>
                </div>
                <div>
                    <div class="flex text-white gap-1 mb-1">
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"
                            ><path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path></svg
                        >
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"
                            ><path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path></svg
                        >
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"
                            ><path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path></svg
                        >
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"
                            ><path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path></svg
                        >
                        <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"
                            ><path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path></svg
                        >
                    </div>
                    <p class="text-white/90 text-sm font-medium">
                        4.9/5 on Google Reviews
                    </p>
                    <p class="text-white/70 text-xs mt-0.5">(520+ ratings)</p>
                </div>
            </div>
        </div>

        <div
            class="relative flex justify-center lg:justify-end items-center mt-12 lg:mt-0"
        >
            <div class="relative flex items-center justify-center">
                <div
                    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[450px] md:w-[650px] md:h-[650px] lg:w-[850px] lg:h-[850px] pointer-events-none z-0"
                >
                    <div
                        class="absolute inset-0 border-[1.5px] border-white/20 rounded-full"
                    >
                    </div>
                    <div
                        class="absolute top-[12%] left-[12%] right-[12%] bottom-[12%] border-[1.5px] border-white/20 rounded-full"
                    >
                    </div>
                    <div
                        class="absolute top-[24%] left-[24%] right-[24%] bottom-[24%] border-[1.5px] border-white/20 rounded-full"
                    >
                    </div>
                </div>

                <div
                    class="w-[320px] h-[320px] md:w-[460px] md:h-[460px] lg:w-[520px] lg:h-[520px] rounded-full overflow-hidden relative z-10 shadow-2xl bg-white"
                >
                    <img
                        src="/hero-img.jpg"
                        alt="Healthy bright smile"
                        class="w-full h-full object-cover"
                    />
                </div>
            </div>
        </div>
    </div>
</section>
