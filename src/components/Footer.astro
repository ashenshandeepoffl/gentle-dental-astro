---
// src/components/Footer.astro

const services = [
    "Emergency Dental Care",
    "Check-Up & Clean",
    "Cosmetic Dentistry",
    "Braces & Orthodontics",
    "Clear Aligners",
    "Root Canals",
];
---

<footer class="bg-white pt-20 pb-8 mt-12 border-t border-brand-light">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 mb-16">
            <div class="lg:col-span-5 flex flex-col gap-6">
                <div class="mb-2">
                    <a href="/" class="flex items-center gap-2 mb-3">
                        <img
                            src="/logo.png"
                            alt="Gentle Dental Logo"
                            class="h-8 w-auto object-contain"
                        />
                        <span
                            class="text-2xl font-bold text-brand-primary tracking-tight"
                            >Gentle Dental</span
                        >
                    </a>
                    <p class="text-gray-500 leading-relaxed">
                        Your Trusted Family Dentist in Burwood. Providing
                        modern, gentle dental care for a confident smile.
                    </p>
                </div>

                <div
                    class="relative w-full h-[250px] rounded-[24px] overflow-hidden border-4 border-brand-light shadow-sm group"
                >
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3150.4140652548185!2d145.15192729999998!3d-37.8506009!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6ad63f71a8fab2b1%3A0xbb59d886e38ecf20!2s332%20Blackburn%20Rd%2C%20Burwood%20East%20VIC%203151%2C%20Australia!5e0!3m2!1sen!2slk!4v1776142489911!5m2!1sen!2slk"
                        class="absolute inset-0 w-full h-full grayscale-[80%] contrast-125 opacity-80"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                    >
                    </iframe>
                    <div
                        class="absolute inset-0 bg-brand-primary mix-blend-color opacity-50 pointer-events-none group-hover:opacity-10 transition-opacity duration-500"
                    >
                    </div>
                </div>

                <div
                    class="flex flex-col sm:flex-row gap-6 text-brand-dark font-medium text-sm mt-2"
                >
                    <div>
                        <p class="text-gray-400 mb-1">Address</p>
                        <p>332 Blackburn Road,</p>
                        <p>Burwood East, VIC 3151</p>
                    </div>
                    <div>
                        <p class="text-gray-400 mb-1">Hours</p>
                        <p>Mon, Wed, Thu: 9:30am – 5:30pm</p>
                        <p>Tue, Fri, Weekends: Closed</p>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-7 grid sm:grid-cols-2 gap-10">
                <div>
                    <h4 class="text-lg font-bold text-brand-dark mb-6">
                        Our Services
                    </h4>
                    <ul class="flex flex-col gap-4">
                        {
                            services.map((service) => (
                                <li>
                                    <a
                                        href="#services"
                                        class="text-gray-500 hover:text-brand-primary transition-colors flex items-center gap-2 group"
                                    >
                                        <svg
                                            class="w-4 h-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all text-brand-primary"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M9 5l7 7-7 7"
                                            />
                                        </svg>
                                        {service}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <div>
                    <h4 class="text-lg font-bold text-brand-dark mb-6">
                        Connect
                    </h4>

                    <div class="flex items-center gap-4 mb-8">
                        <a
                            href="#"
                            aria-label="Facebook"
                            class="w-10 h-10 rounded-full bg-brand-light flex items-center justify-center text-brand-primary hover:bg-brand-primary hover:text-white transition-colors"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                                ></path></svg
                            >
                        </a>
                        <a
                            href="#"
                            aria-label="Instagram"
                            class="w-10 h-10 rounded-full bg-brand-light flex items-center justify-center text-brand-primary hover:bg-brand-primary hover:text-white transition-colors"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm3.98-10.169a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z"
                                ></path></svg
                            >
                        </a>
                        <a
                            href="#"
                            aria-label="TikTok"
                            class="w-10 h-10 rounded-full bg-brand-light flex items-center justify-center text-brand-primary hover:bg-brand-primary hover:text-white transition-colors"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93v7.2c0 1.96-.5 3.96-1.72 5.39-1.62 1.89-4.25 2.65-6.66 2.08-2.65-.62-4.7-2.8-5.26-5.48-.51-2.43.3-5.06 2.1-6.75 1.55-1.47 3.75-2.05 5.84-1.55v4.21c-.81-.19-1.7-.13-2.45.26-.76.38-1.31 1.07-1.5 1.9-.17.75-.12 1.56.23 2.24.41.81 1.25 1.34 2.15 1.43.91.09 1.83-.18 2.53-.78.69-.58 1.1-1.45 1.15-2.36V.02z"
                                ></path></svg
                            >
                        </a>
                        <a
                            href="#"
                            aria-label="LinkedIn"
                            class="w-10 h-10 rounded-full bg-brand-light flex items-center justify-center text-brand-primary hover:bg-brand-primary hover:text-white transition-colors"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                                ></path></svg
                            >
                        </a>
                    </div>

                    <ul class="flex flex-col gap-4 mb-8">
                        <li>
                            <a
                                href="#about"
                                class="text-gray-500 hover:text-brand-primary transition-colors"
                                >About our clinic</a
                            >
                        </li>
                        <li>
                            <a
                                href="#team"
                                class="text-gray-500 hover:text-brand-primary transition-colors"
                                >Meet the team</a
                            >
                        </li>
                        <li>
                            <a
                                href="#blog"
                                class="text-gray-500 hover:text-brand-primary transition-colors"
                                >Dental wellness blog</a
                            >
                        </li>
                    </ul>

                    <a
                        href="#booking"
                        class="inline-flex items-center gap-4 bg-brand-primary text-white font-semibold py-2 pl-6 pr-2 rounded-full hover:bg-cyan-400 transition-all shadow-md group"
                    >
                        Book appointment
                        <span
                            class="bg-white text-brand-primary p-2 rounded-full group-hover:translate-x-1 transition-transform"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-width="2.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"
                                ></path>
                            </svg>
                        </span>
                    </a>
                </div>
            </div>
        </div>

        <div
            class="flex flex-col lg:flex-row items-center justify-between pt-8 border-t border-brand-light text-sm font-medium gap-6"
        >
            <p class="text-gray-400">
                © {new Date().getFullYear()} Gentle Dental. All rights reserved.
            </p>

            <div
                class="flex flex-col sm:flex-row items-center gap-3 sm:gap-6 text-gray-500 bg-brand-light/50 px-6 py-3 rounded-full border border-brand-light"
            >
                <a
                    href="https://axioralabs.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 hover:text-brand-dark transition-colors"
                >
                    Developed by
                    <img
                        src="/axiora-logo.png"
                        alt="Axiora Labs"
                        class="h-4 w-auto object-contain"
                    />
                    <span class="font-bold text-brand-dark">Axiora Labs</span>
                </a>

                <span class="hidden sm:block text-gray-300">|</span>

                <span class="flex items-center gap-2">
                    Hosting in <span class="font-bold text-brand-dark"
                        >Axiora Clouds</span
                    >
                    <svg
                        class="w-4 h-4 text-cyan-500"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"
                        ></path></svg
                    >
                </span>
            </div>
        </div>
    </div>
</footer>
